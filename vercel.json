{
  "buildCommand": "cd client && npm install --legacy-peer-deps --force && npm run build",
  "outputDirectory": "client/build",
  "env": {
    "SKIP_PREFLIGHT_CHECK": "true",
    "GENERATE_SOURCEMAP": "false",
    "CI": "false"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
